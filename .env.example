DEEPSEEK_API_KEY=your_deepseek_api_key_here

# sqlite is the default. Set mysql to store health profiles in MySQL.
APP_PROFILE_STORE=sqlite
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xm2

# Local PDF RAG settings.
APP_VECTOR_DB_DIR=vector_db
APP_VECTOR_COLLECTION=pdf_knowledge
APP_RAG_TOP_K=3
